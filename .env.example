# Copy this file to .env and adjust the values:
#   cp .env.example .env

# Database informations
POSTGRES_USER=flick
POSTGRES_PASSWORD=
POSTGRES_DB=flick
POSTGRES_HOST=flick-postgres
POSTGRES_PORT=5432

# Public address of your Flick instance.
#
# Pick ONE of the following:
#   http://localhost          -> local / dev (default), plain HTTP
#   flick.example.com         -> let the bundled Caddy own your domain and get
#                                automatic HTTPS (Let's Encrypt) + HTTP/3
#   http://flick.example.com  -> you ALREADY have a reverse proxy (Nginx Proxy
#                                Manager, Traefik, another Caddy...) terminating
#                                TLS in front of Flick. Keep the http:// scheme,
#                                no trailing slash. Point your proxy at port 80.
#                                Using https:// here causes a redirect loop
#                                (ERR_TOO_MANY_REDIRECTS).
FLICK_SITE_ADDRESS=http://localhost
