#
# Dev image: next dev with hot reload. Code is bind-mounted at runtime.

FROM node:22-alpine

WORKDIR /app

ENV NODE_ENV=development NEXT_TELEMETRY_DISABLED=1 PORT=3000 HOSTNAME=0.0.0.0

COPY package.json package-lock.json ./
RUN npm ci

EXPOSE 3000

CMD ["npm", "run", "dev"]
